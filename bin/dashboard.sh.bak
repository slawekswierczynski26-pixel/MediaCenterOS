#!/bin/bash

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$DIR/modules/system/system.sh"
source "$DIR/modules/network/network.sh"
source "$DIR/modules/storage/storage.sh"
source "$DIR/modules/media/media.sh"
source "$DIR/modules/audio/audio.sh"

echo "=== TEST ==="
declare -F system_center
declare -F network_center
declare -F storage_center
declare -F media_center
declare -F audio_center

while true
do
    clear

    echo "=================================================="
    echo "                 MediaCenterOS 0.3"
    echo "=================================================="
    echo
    echo "                MENU GŁÓWNE"
    echo
    echo " 1. System"
    echo " 2. Sieć"
    echo " 3. Dyski"
    echo " 4. Multimedia"
    echo " 5. Dźwięk"
    echo
    echo " G. Git"
    echo " Q. Zakończ"
    echo
    echo "=================================================="

    read -rp " Wybór: " WYBOR

    case "$WYBOR" in
        1)
            system_center
            read -rp "Naciśnij ENTER..." _
            ;;

        2)
            network_center
            read -rp "Naciśnij ENTER..." _
            ;;

        3)
            storage_center
            read -rp "Naciśnij ENTER..." _
            ;;

        4)
            media_center
            read -rp "Naciśnij ENTER..." _
            ;;

        5)
            audio_center
            read -rp "Naciśnij ENTER..." _
            ;;

        g|G)
            clear
            git -C "$DIR" status
            echo
            read -rp "Naciśnij ENTER..." _
            ;;

        q|Q)
            clear
            exit 0
            ;;

        *)
            ;;
    esac
done
